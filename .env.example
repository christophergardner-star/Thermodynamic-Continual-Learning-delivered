# TAR environment variables — copy to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# On Windows, set these via: setx VARIABLE_NAME "value"
# TAR reads them from os.environ at runtime.

ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE
RUNPOD_API_KEY=YOUR-RUNPOD-KEY-HERE
RUNPOD_S3_ACCESS_KEY=YOUR-S3-ACCESS-KEY-HERE
RUNPOD_S3_SECRET_KEY=YOUR-S3-SECRET-KEY-HERE
TAR_FTP_HOST=your-ftp-host.com
TAR_FTP_USER=your-ftp-username
TAR_FTP_PASSWORD=your-ftp-password
