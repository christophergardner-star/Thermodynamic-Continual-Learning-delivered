{
  "profile_id": "quantum_ml",
  "domain": "quantum_ml",
  "summary": "Quantum machine-learning environment for variational circuits, barren plateaus, ansatz design, shot-noise studies, and hybrid quantum-classical optimization.",
  "keywords": ["quantum", "qml", "barren plateau", "barren landscapes", "variational circuit", "ansatz", "pennylane", "qiskit", "shot noise", "quantum ai"],
  "base_image": "pytorch/pytorch:latest",
  "python_version": "3.10",
  "cuda_support": "none",
