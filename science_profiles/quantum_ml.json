  "apt_packages": ["git"],
  "validation_imports": ["numpy", "pennylane"],
  "benchmark_targets": ["gradient_norm_variance", "barren_plateau_slope", "trainability_gap", "shot_noise_robustness", "seed_variance"],
  "benchmark_suites": [
