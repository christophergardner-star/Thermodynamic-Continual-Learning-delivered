      "family": "depth_trainability_curve",
      "name": "Smoke QML Depth Trainability",
      "tier": "smoke",
      "dataset_or_env": "local:analytic_qml_probe",
      "metric_protocol": ["gradient_norm_variance", "barren_plateau_slope", "trainability_gap"],
      "canonical_comparable": false,
      "required_imports": ["numpy"],
      "requires_download": false,
      "proxy_allowed": true
    },
